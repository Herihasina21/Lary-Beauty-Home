# Copier vers .env.local : cp env.example .env.local

DATABASE_URL=postgresql://lary:lary@localhost:5433/lary_beauty

# Secret pour les sessions admin (générer une valeur aléatoire longue)
AUTH_SECRET=change-me-to-a-long-random-string

# Compte admin créé au seed
ADMIN_EMAIL=admin@larybeauty.local
ADMIN_PASSWORD=changeme

# URL publique du site (emails, liens de suivi)
SITE_URL=https://www.larybeautyhome.com

# --- Email IONOS (SMTP) ---
# Créez une boîte mail chez IONOS (ex. contact@votredomaine.com)
# Paramètres : smtp.ionos.com — port 587 (STARTTLS) ou 465 (SSL)

SMTP_HOST=smtp.ionos.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@larybeautyhome.com
SMTP_PASS=votre-mot-de-passe-boite-mail

# Expéditeur affiché (souvent identique à SMTP_USER)
MAIL_FROM="Lary Beauty Home <contact@larybeautyhome.com>"
MAIL_REPLY_TO=contact@larybeautyhome.com

# Notification à chaque nouvelle réservation (vous)
MAIL_OWNER=contact@larybeautyhome.com

# Désactiver l'envoi sans retirer la config : MAIL_ENABLED=false
